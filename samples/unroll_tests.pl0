VAR x;

BEGIN
    !100;
    @pragma unroll 4
    FOR x FROM 1 TO 8 DO
        !x;

    !200;
    @pragma unroll 4
    FOR x FROM 1 TO 10 DO
        !x;

    !300;
    @pragma unroll 4
    FOR x FROM 1 TO 3 DO
        !x;

    !400;
    @pragma unroll 3
    FOR x FROM 1 TO 9 BY 2 DO
        !x;

    !500;
    @pragma unroll 0
    FOR x FROM 2 TO 8 BY 2 DO
        !x;

    !600;
    @pragma unroll 1
    FOR x FROM 1 TO 4 DO
        !x;

    !700;
    FOR x FROM 3 TO 7 DO
        !x
END.
